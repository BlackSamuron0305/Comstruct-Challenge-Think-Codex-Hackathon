# ============================================================
# comstruct C-Materials Platform — Root Environment Template
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=comstruct
POSTGRES_USER=comstruct_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://comstruct_app:CHANGE_ME_STRONG_PASSWORD@postgres:5432/comstruct
SYNC_DATABASE_URL=postgresql://comstruct_app:CHANGE_ME_STRONG_PASSWORD@postgres:5432/comstruct

# --- Redis ---
REDIS_PASSWORD=dev_password
REDIS_URL=redis://:dev_password@redis:6379/0

# --- Auth (RS256 JWT) ---
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=comstruct
JWT_AUDIENCE=comstruct-api

# --- AI Service ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_SERVICE_URL=http://ai-service:8005
AI_SERVICE_SECRET=CHANGE_ME_INTERNAL_SECRET

# --- Internal service auth ---
INTERNAL_SHARED_SECRET=CHANGE_ME_INTERNAL_SECRET

# --- Services (internal) ---
ORDER_SERVICE_URL=http://order-service:8002
CATALOG_SERVICE_URL=http://catalog-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004
API_GATEWAY_URL=http://api-gateway:3000

# --- Push Notifications ---
FIREBASE_SERVICE_ACCOUNT_JSON=/run/secrets/firebase.json
APNS_KEY_PATH=/run/secrets/apns.p8
APNS_KEY_ID=CHANGE_ME
APNS_TEAM_ID=CHANGE_ME
APNS_BUNDLE_ID=com.comstruct.mobile

# --- Email ---
RESEND_API_KEY=re_CHANGE_ME
FROM_EMAIL=noreply@comstruct.com

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=comstruct-contracts
S3_ACCESS_KEY=minio_dev_key
S3_SECRET_KEY=minio_dev_secret_change_me
S3_REGION=eu-central-1
S3_USE_SSL=false

# --- Web App (Vite) ---
VITE_API_BASE_URL=http://localhost:8001/api
VITE_WS_URL=ws://localhost:8001/ws
CORS_ORIGIN=http://localhost:8080

# --- Flutter ---
FLUTTER_API_BASE_URL=http://10.0.2.2:3000/api
FLUTTER_WS_URL=ws://10.0.2.2:3000/ws

# --- Compliance / Observability ---
GDPR_DATA_REGION=eu-central-1
AUDIT_LOG_ENABLED=true
SENTRY_DSN=
LOG_LEVEL=info

# --- Approval defaults (fallback if no rule configured) ---
DEFAULT_APPROVAL_THRESHOLD=200.00
DEFAULT_CURRENCY=CHF

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=100
